{
  "info": {
    "name": "Partner Portal API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Full API collection for the Novasoft Partner Portal backend. Base URL: http://localhost:3000/api"
  },
  "variable": [
    { "key": "base_url",      "value": "http://localhost:3000/api" },
    { "key": "token",         "value": "" },
    { "key": "refreshToken",  "value": "" },
    { "key": "registerToken", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "vendorToken",   "value": "" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var r = pm.response.json();",
            "if(r.token){ pm.collectionVariables.set('token', r.token); }",
            "if(r.refreshToken){ pm.collectionVariables.set('refreshToken', r.refreshToken); }"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"securePassword\"\n}" }
          }
        },
        {
          "name": "Login (Customer — Full CRUD)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var r = pm.response.json();",
            "if(r.token){ pm.collectionVariables.set('customerToken', r.token); pm.collectionVariables.set('token', r.token); }",
            "if(r.refreshToken){ pm.collectionVariables.set('refreshToken', r.refreshToken); }"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"testcustomer@partnerportal.com\",\n  \"password\": \"Customer@123\"\n}" }
          }
        },
        {
          "name": "Login (Vendor — Full CRUD)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var r = pm.response.json();",
            "if(r.token){ pm.collectionVariables.set('vendorToken', r.token); pm.collectionVariables.set('token', r.token); }",
            "if(r.refreshToken){ pm.collectionVariables.set('refreshToken', r.refreshToken); }"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"testvendor@partnerportal.com\",\n  \"password\": \"Vendor@123\"\n}" }
          }
        },
        {
          "name": "Get Register Token",
          "event": [{ "listen": "test", "script": { "exec": [
            "var r = pm.response.json();",
            "if(r.registerToken){ pm.collectionVariables.set('registerToken', r.registerToken); }"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/get-register-token",
            "header": []
          }
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": [
            "var r = pm.response.json();",
            "if(r.token){ pm.collectionVariables.set('token', r.token); }"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/refresh-token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/logout",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/verify-token",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/change-password",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"oldPassword\": \"Customer@123\",\n  \"newPassword\": \"NewPassword@456\"\n}" }
          }
        },
        {
          "name": "Create Super Admin",
          "request": {
            "method": "POST", "url": "{{base_url}}/auth/create-super-admin",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Super Admin\",\n  \"email\": \"admin@novasoft.com\",\n  \"password\": \"Password@123\"\n}" }
          }
        }
      ]
    },

