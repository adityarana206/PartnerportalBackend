            }
          ]
        },

        {
          "name": "Submit Price Change",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/vendor/item/price-change",
              "host": ["{{base_url}}"],
              "path": ["api", "vendor", "item", "price-change"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemNo\": \"ITEM-001\",\n  \"variantCode\": \"\",\n  \"newPrice\": 28.00,\n  \"oldPrice\": 25.50,\n  \"effectiveDate\": \"2026-06-01\",\n  \"endingDate\": \"2026-12-31\",\n  \"currencyCode\": \"AED\",\n  \"unitOfMeasureCode\": \"KG\",\n  \"minimumQuantity\": 0,\n  \"partnerNo\": \"VEN000001\",\n  \"rejectionReason\": \"\"\n}"
            }
          },
          "response": [
            {
              "name": "Success",
