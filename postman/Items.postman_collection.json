        {
          "name": "Import Items (CSV / Excel)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/vendor/item/import",
              "host": ["{{base_url}}"],
              "path": ["api", "vendor", "item", "import"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Upload a .csv or .xlsx file. Required columns: partner_portal_no, partner_no, batch_no, item_name. Optional: vendor_item_no, gen_prod_posting_group, vat_prod_posting_group."
                }
              ]
            },
            "description": "Accepts multipart/form-data. File must be CSV or Excel. Download the template first to see all column headers."
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Import completed. 5 items imported successfully, 0 failed\",\n  \"data\": { \"total\": 5, \"success\": 5, \"failed\": 0, \"errors\": [] }\n}"
            }
          ]
        }

      ]
    },

    {
      "name": "UPDATE",
      "item": [

        {
          "name": "Update Item Request (full)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/vendor/item/{{item_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "vendor", "item", "{{item_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemName\": \"Arabic Coffee — Updated\",\n  \"description\": \"Updated description\",\n  \"variantCode\": \"\",\n  \"itemCategoryCode\": \"COFFEE\",\n  \"baseUnitOfMeasure\": \"KG\",\n  \"netWeight\": 1.5,\n  \"grossWeight\": 1.6,\n  \"specifications\": \"Premium quality\",\n  \"ingredients\": \"Coffee beans\",\n  \"allergenDeclaration\": \"None\",\n  \"shelfLifeDays\": 365,\n  \"gtin\": \"1234567890123\",\n  \"eanCode\": \"1234567890123\",\n  \"vendorItemNo\": \"V-ITEM-001\",\n  \"genProdPostingGroup\": \"DOMESTIC\",\n  \"vatProdPostingGroup\": \"VAT5\",\n  \"unitPrice\": 28.00,\n  \"priceCurrencyCode\": \"AED\",\n  \"block\": false,\n  \"status\": \"Created\"\n}"
            },
            "description": "Only allowed when item status = 'Created'. Includes vendorItemNo, genProdPostingGroup, vatProdPostingGroup."
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Item request updated successfully\",\n  \"data\": { \"id\": 1, \"item_name\": \"Arabic Coffee — Updated\", \"vendor_item_no\": \"V-ITEM-001\", \"gen_prod_posting_group\": \"DOMESTIC\", \"vat_prod_posting_group\": \"VAT5\" }\n}"
            },
            {
              "name": "Blocked — Wrong Status",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"Cannot update item with status: Approved. Only 'Created' items can be updated\"\n}"
            }
          ]
        },

        {
          "name": "Update Item Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/vendor/item/{{item_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["api", "vendor", "item", "{{item_id}}", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Approved\",\n  \"rejectionReason\": \"\"\n}"
            },
            "description": "Allowed values: Created | Pending | Approved | Rejected. rejectionReason required when status = Rejected."
          },
          "response": [
            {
              "name": "Approve",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Item status updated to Approved\",\n  \"data\": { \"id\": 1, \"status\": \"Approved\" }\n}"
            },
            {
              "name": "Reject (with reason)",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Item status updated to Rejected\",\n  \"data\": { \"id\": 1, \"status\": \"Rejected\", \"rejection_reason\": \"Allergen info incomplete\" }\n}"
            },
            {
              "name": "Reject — Missing Reason",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"Rejection reason is required when rejecting an item\"\n}"
            }
          ]
        },

