    {
      "name": "DELETE",
      "item": [

        {
          "name": "Delete Item Request",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/vendor/item/{{item_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "vendor", "item", "{{item_id}}"]
            },
            "description": "Only allowed when item status = 'Created'."
          },
          "response": [
            {
              "name": "Success",
