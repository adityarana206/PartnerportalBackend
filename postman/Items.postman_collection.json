            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"block\": true\n}"
            }
          }
        },

        {
          "name": "Unblock Item",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/vendor/item/{{item_id}}/block",
              "host": ["{{base_url}}"],
              "path": ["api", "vendor", "item", "{{item_id}}", "block"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"block\": false\n}"
